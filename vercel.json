{
  "cleanUrls": true,
  "routes": [
    { "src": "/(.*)", "headers": { "X-Content-Type-Options": "nosniff", "X-Frame-Options": "SAMEORIGIN", "Referrer-Policy": "strict-origin-when-cross-origin", "Strict-Transport-Security": "max-age=63072000; includeSubDomains", "Permissions-Policy": "camera=(), microphone=(), geolocation=()" }, "continue": true },
    { "src": "/account.html(.*)", "headers": { "Location": "/pages/account.html$1" }, "status": 301 },
    { "src": "/blog.html(.*)", "headers": { "Location": "/pages/blog.html$1" }, "status": 301 },
    { "src": "/backtesting.html(.*)", "headers": { "Location": "/pages/backtesting.html$1" }, "status": 301 },
    { "src": "/courses.html(.*)", "headers": { "Location": "/pages/courses.html$1" }, "status": 301 },
    { "src": "/payment.html(.*)", "headers": { "Location": "/pages/payment.html$1" }, "status": 301 },
    { "src": "/privacy-policy.html(.*)", "headers": { "Location": "/pages/privacy-policy.html$1" }, "status": 301 },
    { "src": "/refund-policy.html(.*)", "headers": { "Location": "/pages/refund-policy.html$1" }, "status": 301 },
    { "src": "/terms-and-conditions.html(.*)", "headers": { "Location": "/pages/terms-and-conditions.html$1" }, "status": 301 },
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/blog/(.+)", "dest": "/api/article?slug=$1" },
    { "src": "/blog/?", "headers": { "Location": "/pages/blog" }, "status": 301 },
    { "src": "/backtesting(/?.*)", "headers": { "Location": "/pages/backtesting$1" }, "status": 301 },
    { "src": "/courses(/?.*)", "headers": { "Location": "/pages/courses$1" }, "status": 301 },
    { "src": "/account(/?.*)", "headers": { "Location": "/pages/account$1" }, "status": 301 },
    { "src": "/payment(/?.*)", "headers": { "Location": "/pages/payment$1" }, "status": 301 },
    { "src": "/privacy-policy(/?.*)", "headers": { "Location": "/pages/privacy-policy$1" }, "status": 301 },
    { "src": "/refund-policy(/?.*)", "headers": { "Location": "/pages/refund-policy$1" }, "status": 301 },
    { "src": "/refund(/?.*)", "headers": { "Location": "/pages/refund-policy$1" }, "status": 301 },
    { "src": "/terms-and-conditions(/?.*)", "headers": { "Location": "/pages/terms-and-conditions$1" }, "status": 301 },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
